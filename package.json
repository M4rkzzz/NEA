{
  "name": "nea",
  "private": true,
  "version": "1.2.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:app": "tauri dev",
    "check:fast": "tsc --noEmit && cargo check --manifest-path src-tauri/Cargo.toml",
    "build": "tsc && vite build",
    "build:app-fast": "tauri build --debug --no-bundle",
    "build:msi": "tauri build --bundles msi",
    "verify:full": "npm run build && cargo test --manifest-path src-tauri/Cargo.toml && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^1.24.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "@tauri-apps/cli": "^2"
  }
}
