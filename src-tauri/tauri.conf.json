{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NEA",
  "version": "1.2.6",
  "identifier": "com.nea.switcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NEA",
        "width": 980,
        "height": 680,
        "minWidth": 560,
        "minHeight": 420,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "windows": {
      "wix": {
        "upgradeCode": "ad32cc2e-6059-5afe-9ea1-403fa1467432",
        "fragmentPaths": ["wix/legacy-cleanup.wxs"],
        "componentRefs": [
          "RemoveLegacyDesktopShortcut",
          "RemoveLegacyStartMenuShortcuts"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
